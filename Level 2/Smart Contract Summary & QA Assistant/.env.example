# ── Chunking ──────────────────────────────────────────────────────
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200

# ── Embedding Model ──────────────────────────────────────────────
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DEVICE=cuda

# ── Vector Store ─────────────────────────────────────────────────
# CHROMA_COLLECTION=contracts

# ── Retrieval ────────────────────────────────────────────────────
# RETRIEVAL_TOP_K=5

# ── LLM Provider ("openai" or "local") ───────────────────────────
LLM_PROVIDER=openai

# OpenAI API (default provider)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Local GGUF (only needed if LLM_PROVIDER=local)
# LOCAL_MODEL_PATH=./models/your-model.Q4_K_M.gguf
# LLM_N_CTX=4096
# LLM_N_GPU_LAYERS=33

# ── Common LLM Settings ─────────────────────────────────────────
# LLM_TEMPERATURE=0.1
# LLM_MAX_TOKENS=1024

# ── Server ───────────────────────────────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=8000
