# ── Chunking ──────────────────────────────────────────────────────
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200

# ── Embedding Model ──────────────────────────────────────────────
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DEVICE=cuda

# ── Vector Store ─────────────────────────────────────────────────
# CHROMA_COLLECTION=contracts

# ── Retrieval ────────────────────────────────────────────────────
# RETRIEVAL_TOP_K=5

# ── Local LLM (GGUF model for llama-cpp-python) ─────────────────
# LOCAL_MODEL_PATH=./models/mistral-7b-instruct-v0.2.Q4_K_M.gguf
# LLM_N_CTX=4096
# LLM_N_GPU_LAYERS=33
# LLM_TEMPERATURE=0.25
# LLM_MAX_TOKENS=2048
# LLM_MAX_TOKENS_QA=512

# ── Groq (fast cloud LLM; used when LOCAL_MODEL_PATH not set) ─
# GROQ_API_KEY=gsk_...
# Best fit for contract Q&A: llama-3.3-70b-versatile. Faster: llama-3.1-8b-instant, groq/compound-mini
# GROQ_MODEL=llama-3.3-70b-versatile

# ── OpenAI (fallback when Groq key not set) ─
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── Server ───────────────────────────────────────────────────────
# API_HOST=127.0.0.1
# API_PORT=8000
