# ── Chunking ──────────────────────────────────────────────────────
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200

# ── Embedding Model ──────────────────────────────────────────────
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DEVICE=cuda

# ── Vector Store ─────────────────────────────────────────────────
# CHROMA_COLLECTION=contracts

# ── Retrieval ────────────────────────────────────────────────────
# RETRIEVAL_TOP_K=5

# ── LLM Provider ("local" or "openai") ──────────────────────────
LLM_PROVIDER=local

# Local LLM (GGUF model for llama-cpp-python)
LOCAL_MODEL_PATH=./models/your-model.Q4_K_M.gguf
# LLM_N_CTX=4096
# LLM_N_GPU_LAYERS=33
# LLM_TEMPERATURE=0.1
# LLM_MAX_TOKENS=1024

# OpenAI (only needed if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# ── Server ───────────────────────────────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=8000
